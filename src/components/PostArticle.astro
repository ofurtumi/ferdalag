---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import PhotoCarousel from './PhotoCarousel.astro';
import PhotoGrid from './PhotoGrid.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  /** On the feed the title links to the post's own page; on that page it doesn't */
  linkTitle?: boolean;
  /** Feed shows a clickable carousel; the post's own page shows every photo at a glance */
  photoLayout?: 'carousel' | 'grid';
}

const { post, linkTitle = false, photoLayout = 'carousel' } = Astro.props;
const { Content } = await render(post);
const { title, date, location, weather, photos } = post.data;

const dateLabel = date.toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
});
---

<article class="post" id={`post-${post.id}`} data-post-date={date.toISOString().slice(0, 10)}>
  <h2>
    {linkTitle ? <a href={`/posts/${post.id}/`}>{title}</a> : title}
  </h2>
  <p class="post-meta">
    <span>{dateLabel}</span>
    <span>📍 {location}</span>
    {
      weather && (
        <span>
          {weather.temp}°C, {weather.description}
          {weather.windKmh != null && ` · wind ${weather.windKmh} km/h`}
        </span>
      )
    }
  </p>
  <div class="post-body">
    <Content />
  </div>
  {
    photos && photos.length > 0 && (
      photoLayout === 'grid' ? (
        <PhotoGrid photos={photos} alt={`${title}, ${location}`} />
      ) : photos.length > 1 ? (
        <PhotoCarousel photos={photos} alt={`${title}, ${location}`} />
      ) : (
        <Image src={photos[0]} alt={`${title}, ${location}`} widths={[400, 800, 1200]} sizes="(min-width: 48rem) 40rem, 100vw" />
      )
    )
  }
</article>
