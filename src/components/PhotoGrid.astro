---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro:assets';

interface Props {
  photos: ImageMetadata[];
  alt: string;
}

const { photos, alt } = Astro.props;
---

<div class="photo-grid" data-lightbox-group>
  {
    photos.map((photo, i) => (
      <Image
        src={photo}
        alt={`${alt} — photo ${i + 1} of ${photos.length}`}
        widths={[300, 600]}
        sizes="(min-width: 48rem) 20rem, 45vw"
        loading="lazy"
        data-lightbox
      />
    ))
  }
</div>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .photo-grid img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 0.5rem;
    cursor: zoom-in;
  }

  @media (min-width: 30rem) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
